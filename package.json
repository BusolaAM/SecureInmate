    "url": "https://github.com/BusolaAM/SecureInmate/issues"
  },
  "homepage": "https://github.com/BusolaAM/SecureInmate#readme",
  "dependencies": {

    "@fortawesome/free-solid-svg-icons": "^6.4.0",
    "babel": "^6.23.0",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "cloudinary": "^1.37.0",
    "clsx": "^1.2.1",
    "colors": "^1.4.0",
    "concurrently": "^8.0.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-async-handler": "^1.2.0",
    "formik": "^2.4.1",
    "is-empty": "^1.2.0",
    "jsonwebtoken": "^9.0.0",
