    "mongo": "^0.1.0",
    "mongoose": "^7.1.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.1",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^6.9.3",
    "nodemon": "^2.0.22",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "referral-codes": "^2.0.3",
    "slugify": "^1.6.6",
    "sweetalert2": "^11.7.11",
